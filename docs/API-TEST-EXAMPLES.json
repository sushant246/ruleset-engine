{
  "evaluate_api_tests": [
    {
      "description": "Test 1: Basic Order Evaluation - POD Order to US",
      "method": "POST",
      "endpoint": "/api/evaluate",
      "request": {
        "orderId": "1245101",
        "publisherNumber": "99999",
        "publisherName": "BookWorld Ltd",
        "orderMethod": "POD",
        "shipments": [
          {
            "shipTo": {
              "isoCountry": "US"
            }
          }
        ],
        "items": [
          {
            "sku": "PB-001",
            "printQuantity": 10,
            "components": [
              {
                "code": "Cover",
                "attributes": {
                  "bindTypeCode": "PB"
                }
              }
            ]
          }
        ]
      },
      "expectedResponse": {
        "matched": true,
        "productionPlant": "Plant-A",
        "matchedRuleset": "US POD Ruleset",
        "matchedRule": "POD US Rule",
        "reason": "Order matched POD ruleset for US",
        "fallbackUsed": false
      }
    },
