## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools.

# ── Build Results ────────────────────────────────────────────────────────────
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# ── Visual Studio ────────────────────────────────────────────────────────────
.vs/
.vscode/
*.user
*.userosscache
*.sln.docstates
*.suo
*.vcxproj.user
*.vcxproj.*.user
launchSettings.json

# ── .NET Core ────────────────────────────────────────────────────────────────
project.lock.json
project.fragment.lock.json
artifacts/
.dotnet/

# ── ASP.NET Scaffolding ──────────────────────────────────────────────────────
ScaffoldingReadMe.txt

# ── NuGet Packages ───────────────────────────────────────────────────────────
*.nupkg
*.snupkg
.nuget/
nuget.config

# ── Temporary Files ──────────────────────────────────────────────────────────
~$*
*~
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Code Coverage & Analysis ────────────────────────────────────────────────
CodeCoverage/
OpenCover/
*.coverage
*.coveragexml

# ── MSBuild Binary and Structured Log ────────────────────────────────────────
*.binlog
msbuild.log
msbuild.err
msbuild.wrn

# ── Test Results ─────────────────────────────────────────────────────────────
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
trx/
*.trx

# ── Database Files ──────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.mdf
*.ldf

# ── Package Manager Lock Files ──────────────────────────────────────────────
package-lock.json
yarn.lock

# ── IDE & Editor Files ──────────────────────────────────────────────────────
.idea/
*.iml
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json

# ── OS Specific ──────────────────────────────────────────────────────────────
.DS_Store
*.class
*.exe
*.dll
*.pdb

# ── Generated Reports & Coverage ────────────────────────────────────────────
coverage-report/
TestResults/